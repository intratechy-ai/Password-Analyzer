password = input("Enter a password: ")

chars = ""

'''
Logic:
Check what types of characters are present in the password.
If it contains lowercase letters, uppercase letters, digits, or symbols,add those character groups to 'chars'.
This helps estimate how many possible characters could be used at eachposition in the password and calculate the total possible combinations.
'''

for ch in password:
    if ch.islower():
        chars += "abcdefghijklmnopqrstuvwxyz"   
        break
for ch in password:
    if ch.isupper():
        chars += "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
        break
for ch in password:
    if ch.isdigit():
        chars += "0123456789"
        break
symbols = "!@[]#${}%^&*()<>_+-=|;:',./?"

for ch in password:
    if not ch.isalnum(): #if ch is not a letter or number
        chars += symbols
        break

total_combinations = len(chars) ** len(password)    # For each of the n positions in the password, there are len(chars) possible characters
                                                    #-that can fill that position. Mathematically, the total number of possible passwords is len(chars) ** n.
guesses_per_second = 1000000 #assuming

seconds = (total_combinations / 2) / guesses_per_second # We take the average case because the password could be found anywhere between the best case (first attempt) and the worst case (last attempt).
                                                        # On average it is expected to be found around the middle of the search space.
print("\nPassword Analysis")
print("-----------------")
print("Length :", len(password))
print("Character Set Size :", len(chars))
print("Possible Combinations :", total_combinations)

if seconds < 60:
    print("Estimated Crack Time :", round(seconds, 2), "seconds")
elif seconds < 3600:
    print("Estimated Crack Time :", round(seconds / 60, 2), "minutes")
else:
    print("Estimated Crack Time :", round(seconds / 3600, 2), "hours")
